# ============================================================
# Spyfall location images — S3 (Timeweb Cloud)
# ============================================================
# Public base URL to where images live (bucket + prefix). No trailing slash required.
SPYFALL_IMAGE_BASE=https://s3.twcstorage.ru/414f6eff-b78e-450b-8467-faad732fe49a/spyfall
SPYFALL_IMAGE_EXT=jpg

# ============================================================
# Monopoly editor — same bucket, prefix "monopoly/"
# ============================================================
# Public base URL for monopoly logos (server fallback; actual URLs are stored in state.json).
MONOPOLY_IMAGE_BASE=https://s3.twcstorage.ru/414f6eff-b78e-450b-8467-faad732fe49a/monopoly
MONOPOLY_IMAGE_EXT=png

# ============================================================
# S3 credentials
# Used by the server (monopoly admin: read/write state.json, upload logos)
# AND by scripts/upload-spyfall-images.sh.
# Leave S3_ACCESS_KEY / S3_SECRET_KEY blank → server runs in-memory
# (admin panel won't persist changes across restarts).
# ============================================================
S3_ENDPOINT=https://s3.twcstorage.ru
S3_REGION=ru-1
S3_BUCKET=414f6eff-b78e-450b-8467-faad732fe49a
S3_PREFIX=spyfall
S3_ACCESS_KEY=
S3_SECRET_KEY=
